# AGENTUITY_SDK_KEY is a sensitive value and should not be committed to version control.
AGENTUITY_SDK_KEY=your_agentuity_sdk_key_here

# OpenAI API Key - Required for content generation
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Video editor planning pipeline. The v2 multi-step pipeline (brief refiner,
# beat finder, story planner, hook/body/close composers) is the DEFAULT.
# Set to "false" only to force the legacy v1 single-prompt planner.
# VIDEO_EDITOR_USE_V2_PIPELINE=false
